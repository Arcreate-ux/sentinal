# SENTINEL Environment Configuration
# Copy this file to .env and fill in the values before running main.py

# ── Telegram Configuration ──
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"

# ── Notion Configuration ──
NOTION_API_KEY="your_notion_api_key_here"
NOTION_DB1_ID="your_db1_id_here"  # Event Timeline
NOTION_DB2_ID="your_db2_id_here"  # Revision Backlog
NOTION_DB3_ID="your_db3_id_here"  # Master Concepts
NOTION_DB4_ID="your_db4_id_here"  # System Audit Log

# ── LLM Configuration ──
ANTHROPIC_API_KEY="your_anthropic_api_key_here"
OPENAI_API_KEY="your_openai_api_key_here"

# ── MongoDB Configuration ──
MONGODB_URI="mongodb://localhost:27017/"
MONGODB_DB_NAME="sentinel_brain"

# ── Feature Flags ──
ENABLE_ROASTS="true"
ENABLE_STRICT_PACING="true"
